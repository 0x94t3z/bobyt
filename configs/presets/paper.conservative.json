{
  "exchange": {
    "name": "bybit",
    "base_url": "https://api.bytick.com",
    "category": "linear",
    "backup_base_urls": [
      "https://api.bybit.com"
    ]
  },
  "interval": "15m",
  "lookback": 220,
  "scan_every_seconds": 60,
  "state_file": "state/bot_state.json",
  "symbols": [
    "BTCUSDT",
    "ETHUSDT",
    "DEGENUSDT",
    "BASEDUSDT"
  ],
  "spot_discovery": {
    "enabled": true,
    "add_count": 1,
    "min_turnover_usdt": 50000000,
    "min_price_change_pct": 0.03,
    "fallback_to_best": true,
    "exclude_symbols": []
  },
  "strategy": {
    "ema_fast": 9,
    "ema_slow": 26,
    "rsi_period": 14,
    "rsi_buy_min": 54,
    "rsi_buy_max": 66,
    "rsi_sell": 74,
    "limit_pullback_pct": 0.6,
    "take_profit_pct": 1.4,
    "stop_loss_pct": 0.9,
    "regime_filter": {
      "enabled": true,
      "require_uptrend": true,
      "min_trend_pct": 0.12,
      "require_slow_ema_rising": true,
      "min_ema_slope_pct": 0.03
    }
  },
  "risk": {
    "open_on_buy_signal": true,
    "account_equity_usdt": 1000,
    "risk_per_trade_pct": 0.5,
    "max_position_notional_usdt": 150,
    "max_daily_loss_pct": 1.5,
    "max_consecutive_losses": 2,
    "max_open_positions": 1,
    "cooldown_minutes_after_loss": 60,
    "pause_on_limit": true
  },
  "execution_costs": {
    "entry_fee_pct": 0.1,
    "exit_fee_pct": 0.1,
    "entry_slippage_pct": 0.07,
    "exit_slippage_pct": 0.07
  },
  "liquidity_filter": {
    "enabled": true,
    "max_spread_pct": 0.12,
    "min_turnover_24h_usdt": 10000000,
    "block_when_ticker_missing": true
  },
  "journal": {
    "enabled": true,
    "max_closed_trades": 5000,
    "max_execution_events": 1000
  },
  "execution": {
    "mode": "paper",
    "assume_filled_on_submit": true,
    "recv_window_ms": 5000,
    "live_safety": {
      "require_manual_unlock": true,
      "required_ack_phrase": "I_UNDERSTAND_LIVE_TRADING_RISK",
      "require_mainnet_flag": true
    },
    "bybit": {
      "api_key": "",
      "api_secret": ""
    }
  },
  "notifications": {
    "telegram_enabled": false,
    "bot_token": "",
    "chat_id": ""
  }
}
