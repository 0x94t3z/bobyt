# Bybit credentials (leave empty in paper mode)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Live execution safety locks (must all be set for execution.mode=live)
TRADING_BOT_ALLOW_LIVE=false
TRADING_BOT_LIVE_ACK=I_UNDERSTAND_LIVE_TRADING_RISK
TRADING_BOT_ALLOW_MAINNET=false

# Optional: override execution mode without editing config.json
# TRADING_BOT_EXECUTION_MODE=paper

# Optional Telegram env fallback
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Vercel-safe deployment controls
# Force live mode on Vercel only if you intentionally want it (default is paper override).
TRADING_BOT_ALLOW_LIVE_ON_VERCEL=false
# Keep Vercel API authenticated (recommended). Protects /api/scan and /api/status.
TRADING_BOT_REQUIRE_SCAN_AUTH=true
# Token for API auth header: Authorization: Bearer <token> (use this or CRON_SECRET on Vercel).
TRADING_BOT_SCAN_TOKEN=

# Persistent state backend (recommended on Vercel: Neon Postgres)
# file: local JSON file
# postgres: store state/snapshots in Postgres (Neon)
TRADING_BOT_STATE_BACKEND=file
# Prefer pooled Neon URL with sslmode=require
TRADING_BOT_POSTGRES_URL=
# Optional custom table name
# TRADING_BOT_POSTGRES_TABLE=trading_bot_state_store
# Optional explicit keys (defaults are derived from state/status paths)
# TRADING_BOT_STATE_STORAGE_KEY=bot_state_main
# TRADING_BOT_STATUS_STORAGE_KEY=last_scan_snapshot
