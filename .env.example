# -----------------------------
# Exchange credentials (Bybit)
# -----------------------------
# Keep empty for paper mode.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# -----------------------------
# Live-trading safety locks
# -----------------------------
# All 3 must be valid for execution.mode=live.
TRADING_BOT_ALLOW_LIVE=false
TRADING_BOT_LIVE_ACK=I_UNDERSTAND_LIVE_TRADING_RISK
TRADING_BOT_ALLOW_MAINNET=false

# Optional: force runtime mode without editing config JSON.
# Values: paper | live
TRADING_BOT_EXECUTION_MODE=paper

# Vercel-only guard. Keep false unless you intentionally allow live orders on Vercel.
TRADING_BOT_ALLOW_LIVE_ON_VERCEL=false

# -----------------------------
# API auth (recommended ON)
# -----------------------------
# Protects both /api/scan and /api/status.
TRADING_BOT_REQUIRE_SCAN_AUTH=true

# /api/scan token (execution endpoint). Use in header:
# Authorization: Bearer <TRADING_BOT_SCAN_TOKEN>
# If empty, API falls back to CRON_SECRET.
TRADING_BOT_SCAN_TOKEN=

# Required read-only token for /api/status (dashboard endpoint).
# Keep this DIFFERENT from TRADING_BOT_SCAN_TOKEN.
TRADING_BOT_STATUS_TOKEN=

# Optional CORS allow-origin (empty = no cross-origin access).
# Example: https://bobyt.0x94t3z.site
TRADING_BOT_ALLOWED_ORIGIN=

# Optional compatibility token (cron tools often use this name).
# CRON_SECRET=

# Optional debug flag (do NOT enable in production).
# If true, API error responses may include traceback info.
TRADING_BOT_DEBUG_API=false

# Optional scan overlap lock (recommended ON by default behavior).
# Prevents cron and manual /api/scan from running at the same time.
# TRADING_BOT_SCAN_LOCK_NAME=api_scan
# TRADING_BOT_SCAN_LOCK_TTL_SECONDS=180
# TRADING_BOT_SCAN_LOCK_FILE=state/scan_lock.json

# -----------------------------
# State backend
# -----------------------------
# file     -> local JSON state
# postgres -> persistent state in Postgres/Neon
TRADING_BOT_STATE_BACKEND=file

# Preferred explicit DB URL (new name).
NEW_TRADING_BOT_POSTGRES_URL=

# Legacy compatibility URL (optional; use only if new name is empty).
TRADING_BOT_POSTGRES_URL=

# Optional DB URL fallbacks (used if both explicit vars are empty):
# NEON_DATABASE_URL=
# DATABASE_URL=

# Optional legacy switch (kept for compatibility):
# TRADING_BOT_USE_POSTGRES=false

# Optional storage tuning:
# TRADING_BOT_POSTGRES_TABLE=trading_bot_state_store
# TRADING_BOT_CLOSED_TRADES_TABLE=trading_bot_closed_trades
# Optional resiliency toggle:
# true  -> if Postgres is temporarily unavailable, fallback to local file state
# false -> strict mode, fail fast when Postgres is unavailable
TRADING_BOT_POSTGRES_FALLBACK_TO_FILE=true
# Optional but recommended for stable history across local + Vercel:
# (Set the same values in both environments if you want one continuous timeline.)
TRADING_BOT_STATE_STORAGE_KEY=bot_state_main
TRADING_BOT_STATUS_STORAGE_KEY=last_scan_snapshot

# Optional local state path overrides:
# TRADING_BOT_STATE_FILE=state/bot_state.json
# TRADING_BOT_STATUS_FILE=state/last_scan_snapshot.json
# TRADING_BOT_FORCE_CONFIG_STATE_FILE=false

# -----------------------------
# Notifications (optional)
# -----------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
